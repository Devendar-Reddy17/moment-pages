# ===========================================
# MomentPages - Environment Variables
# ===========================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file with real secrets.

# --- Database ---
DATABASE_URL=jdbc:postgresql://localhost:5432/momentpages
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_db_password_here

# --- Backend ---
BACKEND_PORT=8080
BACKEND_URL=http://localhost:8080
SPRING_PROFILES_ACTIVE=local

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=momentpages-media
R2_PUBLIC_URL=https://your-bucket.your-account-id.r2.cloudflarestorage.com

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Application ---
APP_DOMAIN=momentpages.com
MANAGEMENT_TOKEN_LENGTH=64
